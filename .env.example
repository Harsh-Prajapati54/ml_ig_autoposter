# ---------- Groq (content generation) ----------
GROQ_API_KEY=GROQ_API_KEY
# llama-3.3-70b-versatile is being retired on Groq — this default uses the
# recommended replacement. See README "Notes" section.
GROQ_MODEL=openai/gpt-oss-120b
HF_API_KEY=HF_API_KEY
# ---------- Publish mode ----------
# "drive"     -> generate + save each post to a Google Drive folder for you
#                to review and upload to Instagram manually (use this until
#                your IG Business account is linked).
# "instagram" -> generate + publish straight to Instagram via the Graph API.
PUBLISH_MODE=drive

IG_HANDLE=@your.handle

# ---------- Google Drive (required if PUBLISH_MODE=drive) ----------
# See README "Setting up Google Drive" for how to get these, and
# authorize_drive.py for the one-time script that gets the refresh token.
GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=GOOGLE_REFRESH_TOKEN
# Optional: an existing Drive folder ID to nest post-folders inside.
# Leave blank to create them at the root of "My Drive".
GOOGLE_DRIVE_FOLDER_ID=

# ---------- Instagram Graph API (required if PUBLISH_MODE=instagram) ----------
IG_ACCESS_TOKEN=your_long_lived_access_token
IG_USER_ID=your_instagram_business_account_id
GRAPH_API_VERSION=v21.0

# ---------- GitHub (always required — used for topic rotation state, post
# history, and as image hosting when PUBLISH_MODE=instagram) ----------
# Locally you need a Personal Access Token (fine-grained, "Contents: Read
# and write" on the target repo). Inside GitHub Actions this is filled in
# automatically from secrets.GITHUB_TOKEN — you don't need to set it there.
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=Harsh-Prajapati54
GITHUB_REPO=ml-ig-post-assets
GITHUB_BRANCH=main
